{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "Build Angular App",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Build Server",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "PyInstaller",
        "deployment\\ElectronServer.spec",
        "--distpath",
        "deployment",
        "--workpath",
        "deployment/serverBuild",
        "--noconfirm"
      ],
      "dependsOn": ["Delete Server Build"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Build Electron App",
      "type": "npm",
      "script": "build-electron",
      "options": {
        "env": {
          "ELECTRON_CACHE": "${workspaceFolder}/caches/electron",
          "ELECTRON_BUILDER_CACHE": "${workspaceFolder}/caches/electron-builder"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Delete Server Build",
      "type": "shell",
      "command": "IF EXIST ${workspaceFolder}\\deployment\\ElectronServer RD /s /q ${workspaceFolder}\\deployment\\ElectronServer"
    },
    {
      "label": "Delete App Build",
      "type": "shell",
      "command": "IF EXIST ${workspaceFolder}\\deployment\\ElectronApp RD /s /q ${workspaceFolder}\\deployment\\ElectronApp"
    },
    {
      "label": "end ng serve",
      "type": "process",
      "command": ["${command:workbench.action.tasks.terminate}"],
      "presentation": {
        "panel": "dedicated",
        "close": true // Close the terminal when the task finishes
      },
      "dependsOn": ["npm: start"]
    },
    {
      "label": "Full Build",
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["Build Angular App", "Build Server", "Delete App Build", "Build Electron App"]
    }
  ]
}
