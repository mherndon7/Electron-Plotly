{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "ng serve",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "npm: start",
      "url": "http://localhost:4200/"
    },
    {
      "name": "ng test",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "npm: test",
      "url": "http://localhost:9876/debug.html"
    },
    {
      "name": "Start Server: Development",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/server",
      "args": ["server", "--dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Start Server",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/server",
      "args": ["server"],
      "console": "integratedTerminal"
    },
    {
      "name": "Renderer",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Electron App: Script",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": [".", "--remote-debugging-port=9222", "script"],
      "outputCapture": "std",
      "console": "integratedTerminal"
    },
    {
      "name": "Electron App: Server Executable",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": [".", "--remote-debugging-port=9222"],
      "outputCapture": "std",
      "console": "integratedTerminal"
    },
    {
      "name": "Electron App: Development",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": [".", "--remote-debugging-port=9222", "development"],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "preLaunchTask": "npm: start",
      "postDebugTask": "end ng serve"
    }
  ],
  "compounds": [
    {
      "name": "Electron App + Renderer: Development",
      "configurations": ["Start Server: Development", "Electron App: Development", "Renderer"],
      "stopAll": true
    },
    {
      "name": "Electron App + Renderer: Script",
      "configurations": ["Electron App: Script", "Renderer"],
      "stopAll": true
    },
    {
      "name": "Electron App + Renderer: Script (Build Angular)",
      "configurations": ["Electron App: Script", "Renderer"],
      "preLaunchTask": "Build Angular App",
      "stopAll": true
    },
    {
      "name": "Electron App + Renderer: Server Executable",
      "configurations": ["Electron App: Server Executable", "Renderer"],
      "stopAll": true
    },
    {
      "name": "Electron App + Renderer: Server Executable (Build Angular)",
      "configurations": ["Electron App: Server Executable", "Renderer"],
      "preLaunchTask": "Build Angular App",
      "stopAll": true
    }
  ]
}
