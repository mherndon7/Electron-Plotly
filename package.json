{
  "name": "electron-app",
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-electron": "electron .",
    "build": "ng build --base-href ./ --configuration production",
    "build-electron": "electron-builder build --publish never",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "build": {
    "appId": "com.electron-plotly.app",
    "files": [
      "deployment/dist/**/*",
      "main.js",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "deployment/ElectronServer",
        "to": "extras",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "deployment/dist",
        "to": "extras/ui",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "deployment/ElectronApp",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "zip",
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "angular-plotly": "^0.1.3",
    "angular-plotly.js": "^20.0.0",
    "electron-log": "^5.4.3",
    "plotly.js-dist-min": "^3.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@types/plotly.js-dist-min": "^2.3.4",
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
